+"""Title-based deduplication using TF-IDF cosine similarity."""
+from __future__ import annotations
+
+from typing import Optional
+
+
+def deduplicate_articles(
+    titles: list[str],
+    threshold: float = 0.85,
+) -> list[int]:
+    """
+    Find duplicate article titles using TF-IDF cosine similarity.
+
+    Returns list of indices that are duplicates (should be excluded).
+    Two articles are considered duplicates if their title similarity > threshold.
+    """
+    if len(titles) < 2:
+        return []
+
+    try:
+        from sklearn.feature_extraction.text import TfidfVectorizer
+        from sklearn.metrics.pairwise import cosine_similarity
+        import numpy as np
+    except ImportError:
+        # scikit-learn not installed — skip title dedup, URL dedup still active
+        return []
+
+    vectorizer = TfidfVectorizer(
+        stop_words="english",
+        ngram_range=(1, 2),
+        min_df=1,
+        max_features=5000,
+    )
+
+    try:
+        tfidf_matrix = vectorizer.fit_transform(titles)
+    except Exception:
+        return []
+
+    similarity_matrix = cosine_similarity(tfidf_matrix)
+    duplicates: set[int] = set()

+    for i in range(len(titles)):
+        if i in duplicates:
+            continue
+        for j in range(i + 1, len(titles)):
+            if j in duplicates:
+                continue
+            if similarity_matrix[i, j] >= threshold:
+                duplicates.add(j)  # keep i, mark j as duplicate

+    return sorted(duplicates)
+
+
+def mark_db_duplicates(db_session, threshold: float = 0.85) -> int:
+    """
+    Scan recent unprocessed raw_articles and mark title-similar articles as duplicates.
+    Returns count of articles marked as duplicate.
+    """
+    from src.cddbs.models import RawArticle
+    from datetime import datetime, UTC, timedelta

+    # Process articles from the last 2 hours
+    cutoff = datetime.now(UTC).replace(tzinfo=None) - timedelta(hours=2)
+    articles = (
+        db_session.query(RawArticle)
+        .filter(RawArticle.created_at >= cutoff, RawArticle.is_duplicate == 0)
+        .order_by(RawArticle.created_at.asc())
+        .all()
+    )

+    if len(articles) < 2:
+        return 0

+    titles = [a.title for a in articles]
+    duplicate_indices = deduplicate_articles(titles, threshold=threshold)

+    for idx in duplicate_indices:
+        canonical_idx = 0
+        # Find the canonical (first non-duplicate) article above this one
+        for k in range(idx):
+            if k not in duplicate_indices:
+                canonical_idx = k
+                break
+        articles[idx].is_duplicate = 1
+        articles[idx].duplicate_of = articles[canonical_idx].id

+    if duplicate_indices:
+        db_session.commit()

+    return len(duplicate_indices)
