@@ -0,0 +1,120 @@
+"""Enhanced GDELT collector using Doc API v2."""
+from __future__ import annotations
+
+import re
+from datetime import datetime, timezone
+from typing import Optional
+from urllib.parse import urlparse
+
+from src.cddbs.collectors.base import BaseCollector, RawArticleData
+
+GDELT_DOC_API = "https://api.gdeltproject.org/api/v2/doc/doc"
+GDELT_EVENTS_API = "https://api.gdeltproject.org/api/v2/events/search"
+
+
+def _extract_domain(url: str) -> str:
+    try:
+        return urlparse(url).netloc.replace("www.", "")
+    except Exception:
+        return ""
+
+
+def _parse_gdelt_datetime(dt_str: Optional[str]) -> Optional[datetime]:
+    """Parse GDELT datetime format: YYYYMMDDHHMMSS"""
+    if not dt_str:
+        return None
+    try:
+        return datetime.strptime(dt_str[:14], "%Y%m%d%H%M%S")
+    except Exception:
+        return None
+
+
+class GDELTCollector(BaseCollector):
+    """Fetches articles from GDELT Doc API v2 (no API key required)."""
+
+    def __init__(
+        self,
+        query: str = "disinformation OR propaganda OR information operation",
+        max_records: int = 50,
+        mode: str = "ArtList",
+        timespan: str = "15min",
+    ):
+        self._query = query
+        self._max_records = max_records
+        self._mode = mode
+        self._timespan = timespan
+        self._healthy = True
+        self._last_error: Optional[str] = None
+
+    @property
+    def name(self) -> str:
+        return "gdelt"
+
+    @property
+    def is_healthy(self) -> bool:
+        return self._healthy
+
+    @property
+    def last_error(self) -> Optional[str]:
+        return self._last_error
+
+    async def collect(self) -> list[RawArticleData]:
+        """Fetch articles from GDELT Doc API."""
+        try:
+            import httpx
+        except ImportError:
+            self._last_error = "httpx not installed"
+            self._healthy = False
+            return []
+
+        params = {
+            "query": self._query,
+            "mode": self._mode,
+            "maxrecords": self._max_records,
+            "timespan": self._timespan,
+            "format": "json",
+            "sort": "DateDesc",
+        }
+
+        try:
+            async with httpx.AsyncClient(timeout=30.0) as client:
+                response = await client.get(GDELT_DOC_API, params=params)
+                response.raise_for_status()
+                data = response.json()
+        except Exception as e:
+            self._last_error = f"GDELT API request failed: {e}"
+            self._healthy = False
+            return []
+
+        articles: list[RawArticleData] = []
+        for item in data.get("articles", []):
+            url = item.get("url", "")
+            title = item.get("title", "")
+            if not url or not title:
+                continue
+
+            tone = item.get("tone", "")
+            try:
+                tone_score = float(tone.split(",")[0]) if tone else 0.0
+            except Exception:
+                tone_score = 0.0

+            published_at = _parse_gdelt_datetime(item.get("seendate"))
+
+            articles.append(RawArticleData(
+                title=title,
+                url=url,
+                content=None,  # GDELT does not return full text
+                source_name=item.get("domain", _extract_domain(url)),
+                source_domain=_extract_domain(url),
+                source_type="gdelt",
+                published_at=published_at,
+                language=item.get("language"),
+                country=item.get("sourcecountry"),
+                raw_meta={
+                    "gdelt_tone": tone_score,
+                    "gdelt_domain": item.get("domain"),
+                    "gdelt_socialimage": item.get("socialimage"),
+                },
+            ))

+        self._healthy = True
+        self._last_error = None
+        return articles
