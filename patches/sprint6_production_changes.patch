@@ -0,0 +1,126 @@
+"""RSS feed collector using feedparser."""
+from __future__ import annotations
+
+import json
+import os
+from datetime import datetime, timezone
+from email.utils import parsedate_to_datetime
+from typing import Optional
+from urllib.parse import urlparse
+
+from src.cddbs.collectors.base import BaseCollector, RawArticleData
+
+
+def _parse_date(date_str: Optional[str]) -> Optional[datetime]:
+    """Parse RFC-2822 or ISO date string to datetime."""
+    if not date_str:
+        return None
+    try:
+        return parsedate_to_datetime(date_str).astimezone(timezone.utc).replace(tzinfo=None)
+    except Exception:
+        try:
+            return datetime.fromisoformat(date_str.rstrip("Z")).replace(tzinfo=None)
+        except Exception:
+            return None
+
+
+def _extract_domain(url: str) -> str:
+    try:
+        return urlparse(url).netloc.replace("www.", "")
+    except Exception:
+        return ""
+
+
+class RSSCollector(BaseCollector):
+    """Collects articles from a list of RSS feeds."""
+
+    def __init__(self, feeds_path: Optional[str] = None):
+        self._feeds_path = feeds_path or os.environ.get(
+            "RSS_FEEDS_PATH", "src/cddbs/data/rss_feeds.json"
+        )
+        self._feeds: list[dict] = []
+        self._healthy = True
+        self._last_error: Optional[str] = None
+        self._load_feeds()
+
+    def _load_feeds(self):
+        try:
+            with open(self._feeds_path, "r") as f:
+                data = json.load(f)
+            self._feeds = data.get("feeds", [])
+        except Exception as e:
+            self._last_error = f"Failed to load RSS feeds config: {e}"
+            self._healthy = False
+            self._feeds = []
+
+    @property
+    def name(self) -> str:
+        return "rss"
+
+    @property
+    def is_healthy(self) -> bool:
+        return self._healthy
+
+    @property
+    def last_error(self) -> Optional[str]:
+        return self._last_error
+
+    async def collect(self) -> list[RawArticleData]:
+        """Fetch and parse all configured RSS feeds."""
+        try:
+            import feedparser
+        except ImportError:
+            self._last_error = "feedparser not installed"
+            self._healthy = False
+            return []
+
+        articles: list[RawArticleData] = []
+        self._healthy = True
+        self._last_error = None
+
+        for feed_config in self._feeds:
+            feed_url = feed_config.get("url", "")
+            feed_name = feed_config.get("name", feed_url)
+            category = feed_config.get("category", "general")
+
+            try:
+                feed = feedparser.parse(feed_url)
+                if feed.bozo and not feed.entries:
+                    continue
+
+                for entry in feed.entries[:50]:  # cap at 50 per feed
+                    url = entry.get("link", "")
+                    title = entry.get("title", "")
+                    if not url or not title:
+                        continue
+
+                    content = (
+                        entry.get("summary")
+                        or entry.get("description")
+                        or ""
+                    )
+
+                    published_str = entry.get("published") or entry.get("updated")
+                    published_at = _parse_date(published_str)
+
+                    articles.append(RawArticleData(
+                        title=title,
+                        url=url,
+                        content=content[:2000] if content else None,
+                        source_name=feed_name,
+                        source_domain=_extract_domain(url),
+                        source_type="rss",
+                        published_at=published_at,
+                        language=feed_config.get("language", "en"),
+                        country=None,
+                        raw_meta={
+                            "feed_category": category,
+                            "feed_reliability": feed_config.get("reliability", "medium"),
+                        },
+                    ))
+
+            except Exception as e:
+                # One feed failure must not stop others
+                print(f"RSS collector: feed {feed_name} failed: {e}")
+                continue
+
+        return articles
