+++ b/src/cddbs/collectors/manager.py
@@ -0,0 +1,152 @@
+"""CollectorManager: async scheduling and storage of collected articles."""
+from __future__ import annotations
+
+import asyncio
+import hashlib
+from datetime import datetime, UTC
+from typing import Optional
+
+from src.cddbs.collectors.base import BaseCollector, RawArticleData
+from src.cddbs.collectors.rss import RSSCollector
+from src.cddbs.collectors.gdelt import GDELTCollector
+from src.cddbs.database import SessionLocal
+from src.cddbs.models import RawArticle
+
+
+def _url_hash(url: str) -> str:
+    return hashlib.sha256(url.encode("utf-8")).hexdigest()
+
+
+def _persist_articles(articles: list[RawArticleData]) -> dict:
+    """Store articles in DB, skipping URL duplicates. Returns stats."""
+    db = SessionLocal()
+    stored = 0
+    skipped = 0
+    try:
+        for article in articles:
+            url_hash = _url_hash(article.url)
+            exists = db.query(RawArticle).filter(
+                RawArticle.url_hash == url_hash
+            ).first()
+            if exists:
+                skipped += 1
+                continue
+
+            row = RawArticle(
+                url_hash=url_hash,
+                title=article.title,
+                url=article.url,
+                content=article.content,
+                source_name=article.source_name,
+                source_domain=article.source_domain,
+                source_type=article.source_type,
+                published_at=article.published_at,
+                language=article.language,
+                country=article.country,
+                raw_meta=article.raw_meta,
+                created_at=datetime.now(UTC).replace(tzinfo=None),
+            )
+            db.add(row)
+            stored += 1
+
+        db.commit()
+    except Exception as e:
+        db.rollback()
+        print(f"CollectorManager: DB persist failed: {e}")
+    finally:
+        db.close()
+
+    return {"stored": stored, "skipped_duplicates": skipped}
+
+
+class CollectorManager:
+    """Manages multiple collectors with independent scheduling."""
+
+    def __init__(
+        self,
+        rss_interval: int = 180,
+        gdelt_interval: int = 300,
+        feeds_path: Optional[str] = None,
+    ):
+        self._rss = RSSCollector(feeds_path=feeds_path)
+        self._gdelt = GDELTCollector()
+        self._collectors: list[BaseCollector] = [self._rss, self._gdelt]
+        self._rss_interval = rss_interval
+        self._gdelt_interval = gdelt_interval
+        self._running = False
+        self._tasks: list[asyncio.Task] = []
+        self._stats: dict = {
+            "rss": {"runs": 0, "stored": 0, "skipped": 0, "last_run": None, "last_error": None},
+            "gdelt": {"runs": 0, "stored": 0, "skipped": 0, "last_run": None, "last_error": None},
+        }
+
+    async def _run_collector(self, collector: BaseCollector, interval: int):
+        """Run a single collector on a fixed interval."""
+        while self._running:
+            start = datetime.now(UTC)
+            try:
+                articles = await collector.collect()
+                result = _persist_articles(articles)
+                self._stats[collector.name]["runs"] += 1
+                self._stats[collector.name]["stored"] += result["stored"]
+                self._stats[collector.name]["skipped"] += result["skipped_duplicates"]
+                self._stats[collector.name]["last_run"] = start.isoformat()
+                self._stats[collector.name]["last_error"] = collector.last_error
+                print(
+                    f"Collector {collector.name}: fetched {len(articles)} articles, "
+                    f"stored {result['stored']}, skipped {result['skipped_duplicates']}"
+                )
+            except Exception as e:
+                self._stats[collector.name]["last_error"] = str(e)
+                print(f"Collector {collector.name} error: {e}")
+
+            await asyncio.sleep(interval)
+
+    async def start(self):
+        """Start all collectors as background tasks."""
+        self._running = True
+        self._tasks = [
+            asyncio.create_task(self._run_collector(self._rss, self._rss_interval)),
+            asyncio.create_task(self._run_collector(self._gdelt, self._gdelt_interval)),
+        ]
+        print(f"CollectorManager started: RSS every {self._rss_interval}s, GDELT every {self._gdelt_interval}s")
+
+    async def stop(self):
+        """Stop all collectors."""
+        self._running = False
+        for task in self._tasks:
+            task.cancel()
+        await asyncio.gather(*self._tasks, return_exceptions=True)
+        self._tasks = []
+        print("CollectorManager stopped")
+
+    def status(self) -> dict:
+        """Return per-collector health and stats."""
+        return {
+            name: {
+                **stats,
+                "healthy": self._get_collector(name).is_healthy,
+                "last_error": self._get_collector(name).last_error or stats.get("last_error"),
+            }
+            for name, stats in self._stats.items()
+        }
+
+    def _get_collector(self, name: str) -> BaseCollector:
+        for c in self._collectors:
+            if c.name == name:
+                return c
+        raise KeyError(f"Unknown collector: {name}")
+
+
+# Global singleton — initialized in FastAPI lifespan
+_manager: Optional[CollectorManager] = None
+
+
+def get_manager() -> Optional[CollectorManager]:
+    return _manager
+
+
+def init_manager(rss_interval: int = 180, gdelt_interval: int = 300, feeds_path: Optional[str] = None):
+    global _manager
+    _manager = CollectorManager(
+        rss_interval=rss_interval,
+        gdelt_interval=gdelt_interval,
+        feeds_path=feeds_path,
+    )
+    return _manager
