+"""Tests for Sprint 6 TF-IDF deduplication."""
+import pytest
+
+
+def test_deduplicate_identical_titles():
+    from src.cddbs.pipeline.deduplication import deduplicate_articles
+    titles = [
+        "Russia launches strikes on Kyiv infrastructure",
+        "Russia launches strikes on Kyiv infrastructure",
+        "US announces new sanctions package against Russia",
+    ]
+    dupes = deduplicate_articles(titles, threshold=0.85)
+    assert 1 in dupes  # second title is a duplicate of first
+    assert 0 not in dupes  # first is canonical
+    assert 2 not in dupes  # third is unique
+
+
+def test_deduplicate_near_identical_titles():
+    from src.cddbs.pipeline.deduplication import deduplicate_articles
+    titles = [
+        "Russia launches missile strikes on Kyiv power infrastructure",
+        "Russia launches missile strikes on Kyiv power infrastructure — update",
+        "NATO pledges additional military aid to Ukraine",
+    ]
+    dupes = deduplicate_articles(titles, threshold=0.85)
+    # Near-identical titles should trigger dedup
+    assert len(dupes) >= 0  # At threshold 0.85, may or may not match — just ensure no crash
+
+
+def test_deduplicate_unique_titles():
+    from src.cddbs.pipeline.deduplication import deduplicate_articles
+    titles = [
+        "Russia targets Kyiv",
+        "China holds military exercises near Taiwan",
+        "WHO declares monkeypox emergency",
+        "IMF upgrades global growth forecast",
+    ]
+    dupes = deduplicate_articles(titles, threshold=0.85)
+    assert dupes == []  # All unique


+def test_deduplicate_single_title():
+    from src.cddbs.pipeline.deduplication import deduplicate_articles
+    dupes = deduplicate_articles(["Single title"], threshold=0.85)
+    assert dupes == []
+
+
+def test_deduplicate_empty():
+    from src.cddbs.pipeline.deduplication import deduplicate_articles
+    dupes = deduplicate_articles([], threshold=0.85)
+    assert dupes == []
