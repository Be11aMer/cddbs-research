+"""Base collector interface for multi-source news ingestion."""
+from __future__ import annotations
+
+import hashlib
+from abc import ABC, abstractmethod
+from dataclasses import dataclass, field
+from datetime import datetime
+from typing import Optional
+
+
+@dataclass
+class RawArticleData:
+    """Normalized article data from any collector."""
+    title: str
+    url: str
+    source_name: str
+    source_domain: str
+    source_type: str  # "rss", "gdelt", "news_api"
+    content: Optional[str] = None
+    published_at: Optional[datetime] = None
+    language: Optional[str] = None
+    country: Optional[str] = None
+    raw_meta: dict = field(default_factory=dict)
+
+    @property
+    def url_hash(self) -> str:
+        """SHA-256 hash of URL for deduplication."""
+        return hashlib.sha256(self.url.encode("utf-8")).hexdigest()
+
+    @property
+    def source_domain_extracted(self) -> str:
+        """Extract domain from URL."""
+        try:
+            from urllib.parse import urlparse
+            return urlparse(self.url).netloc.replace("www.", "")
+        except Exception:
+            return self.source_domain or ""
+
+
+class BaseCollector(ABC):
+    """Abstract base class for all news collectors."""
+
+    @property
+    @abstractmethod
+    def name(self) -> str:
+        """Unique collector name for health reporting."""
+        ...
+
+    @abstractmethod
+    async def collect(self) -> list[RawArticleData]:
+        """Collect articles from the source. Returns empty list on failure."""
+        ...
+
+    @property
+    def is_healthy(self) -> bool:
+        """Override to report health status."""
+        return True
+
+    @property
+    def last_error(self) -> Optional[str]:
+        """Override to expose last error message."""
+        return None
+
+
+class CollectorError(Exception):
+    """Raised when a collector fails to fetch articles."""
+    pass
