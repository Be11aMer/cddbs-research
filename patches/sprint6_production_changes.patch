+"""Tests for Sprint 6 collector infrastructure."""
+import hashlib
+import pytest
+from unittest.mock import AsyncMock, MagicMock, patch
+
+from src.cddbs.collectors.base import RawArticleData, BaseCollector
+from src.cddbs.collectors.rss import RSSCollector
+from src.cddbs.collectors.gdelt import GDELTCollector
+
+
+# ---------------------------------------------------------------------------
+# RawArticleData
+# ---------------------------------------------------------------------------
+
+def test_raw_article_url_hash():
+    article = RawArticleData(
+        title="Test Article",
+        url="https://example.com/article",
+        source_name="Test Source",
+        source_domain="example.com",
+        source_type="rss",
+    )
+    expected = hashlib.sha256("https://example.com/article".encode()).hexdigest()
+    assert article.url_hash == expected
+
+
+def test_raw_article_domain_extraction():
+    article = RawArticleData(
+        title="Test",
+        url="https://www.reuters.com/world/test-story",
+        source_name="Reuters",
+        source_domain="",
+        source_type="rss",
+    )
+    assert article.source_domain_extracted == "reuters.com"
+
+
+def test_raw_article_defaults():
+    article = RawArticleData(
+        title="Test",
+        url="https://example.com",
+        source_name="S",
+        source_domain="example.com",
+        source_type="gdelt",
+    )
+    assert article.content is None
+    assert article.published_at is None
+    assert article.raw_meta == {}
+
+
+# ---------------------------------------------------------------------------
+# RSSCollector
+# ---------------------------------------------------------------------------
+
+def test_rss_collector_name():
+    collector = RSSCollector(feeds_path="/nonexistent/path.json")
+    assert collector.name == "rss"
+    assert collector.is_healthy is False  # load failed
+    assert "Failed to load" in (collector.last_error or "")
+
+
+@pytest.mark.asyncio
+async def test_rss_collector_empty_on_missing_feedparser(tmp_path):
+    """If feedparser is not importable, collector returns empty list."""
+    feeds_file = tmp_path / "feeds.json"
+    feeds_file.write_text('{"feeds": [{"name": "Test", "url": "https://example.com/rss", "category": "test", "language": "en"}]}')
+    collector = RSSCollector(feeds_path=str(feeds_file))
+
+    with patch("builtins.__import__", side_effect=ImportError("feedparser")):
+        result = await collector.collect()
+    # Should return empty list, not raise
+    assert isinstance(result, list)
+
+
+@pytest.mark.asyncio
+async def test_rss_collector_skips_bad_feeds(tmp_path):
+    """A bad feed URL should not crash the collector; other feeds continue."""
+    feeds_file = tmp_path / "feeds.json"
+    feeds_file.write_text('{"feeds": [{"name": "Bad", "url": "not-a-url", "category": "test", "language": "en"}]}')
+    collector = RSSCollector(feeds_path=str(feeds_file))
+
+    with patch("feedparser.parse", side_effect=Exception("network error")):
+        result = await collector.collect()
+    assert isinstance(result, list)
+
+
+# ---------------------------------------------------------------------------
+# GDELTCollector
+# ---------------------------------------------------------------------------
+
+def test_gdelt_collector_name():
+    collector = GDELTCollector()
+    assert collector.name == "gdelt"
+    assert collector.is_healthy is True
+
+
+@pytest.mark.asyncio
+async def test_gdelt_collector_returns_empty_on_http_failure():
+    collector = GDELTCollector()
+    with patch("httpx.AsyncClient") as mock_client:
+        mock_client.return_value.__aenter__.return_value.get = AsyncMock(side_effect=Exception("connection refused"))
+        result = await collector.collect()
+    assert result == []
+    assert collector.is_healthy is False
