+"""
+CDDBS Analysis Metrics
+
+Computes operational metrics from the database: success rates, quality trends,
+analysis durations, and failure reasons.
+"""
+
+from datetime import datetime, UTC, timedelta
+from sqlalchemy.orm import Session
+from src.cddbs.models import Report, Briefing, NarrativeMatch
+
+
+def compute_metrics(db: Session) -> dict:
+    """Compute operational metrics across all analysis runs."""
+    reports = db.query(Report).all()
+
+    total = len(reports)
+    if total == 0:
+        return {
+            "total_runs": 0,
+            "completed": 0,
+            "failed": 0,
+            "running": 0,
+            "success_rate": 0.0,
+            "avg_quality_score": None,
+            "total_narratives_detected": 0,
+            "failure_reasons": [],
+            "quality_distribution": {"excellent": 0, "good": 0, "acceptable": 0, "poor": 0, "failing": 0},
+            "recent_24h": {"total": 0, "completed": 0, "failed": 0, "success_rate": None},
+        }
+
+    completed = 0
+    failed = 0
+    running = 0
+    failure_reasons = []
+
+    for r in reports:
+        data = r.data or {}
+        errors = data.get("errors") if isinstance(data, dict) else None
+        if errors:
+            failed += 1
+            for err in errors:
+                failure_reasons.append(str(err)[:200])
+        elif not r.final_report:
+            running += 1
+        else:
+            completed += 1
+
+    # Quality metrics from briefings
+    briefings = db.query(Briefing).filter(Briefing.quality_score.isnot(None)).all()
+    quality_scores = [b.quality_score for b in briefings]
+    avg_quality = sum(quality_scores) / len(quality_scores) if quality_scores else None
+
+    quality_dist = {"excellent": 0, "good": 0, "acceptable": 0, "poor": 0, "failing": 0}
+    for b in briefings:
+        rating = (b.quality_rating or "").lower()
+        if rating in quality_dist:
+            quality_dist[rating] += 1
+
+    # Narrative metrics
+    total_narrative_matches = db.query(NarrativeMatch).count()
+
+    # Recent metrics (last 24h)
+    cutoff = datetime.now(UTC) - timedelta(hours=24)
+    recent_reports = [r for r in reports if r.created_at and r.created_at.replace(tzinfo=UTC) > cutoff]
+    recent_total = len(recent_reports)
+    recent_completed = 0
+    recent_failed = 0
+    for r in recent_reports:
+        data = r.data or {}
+        errors = data.get("errors") if isinstance(data, dict) else None
+        if errors:
+            recent_failed += 1
+        elif r.final_report:
+            recent_completed += 1
+
+    success_rate = (completed / total * 100) if total > 0 else 0.0
+    recent_success_rate = (recent_completed / recent_total * 100) if recent_total > 0 else None
+
+    return {
+        "total_runs": total,
+        "completed": completed,
+        "failed": failed,
+        "running": running,
+        "success_rate": round(success_rate, 1),
+        "avg_quality_score": round(avg_quality, 1) if avg_quality is not None else None,
+        "total_narratives_detected": total_narrative_matches,
+        "quality_distribution": quality_dist,
+        "failure_reasons": failure_reasons[-10:],  # Last 10 failures
+        "recent_24h": {
+            "total": recent_total,
+            "completed": recent_completed,
+            "failed": recent_failed,
+            "success_rate": round(recent_success_rate, 1) if recent_success_rate is not None else None,
+        },
+    }
