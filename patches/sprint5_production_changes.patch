+"""
+Twitter API v2 Client for CDDBS
+
+Fetches tweets and profile data from Twitter/X using API v2 Bearer Token auth.
+Normalizes data via TwitterAdapter into the analysis pipeline format.
+"""
+
+import time
+import requests
+from typing import List, Dict, Optional
+from src.cddbs.config import settings
+from src.cddbs.adapters import TwitterAdapter, BriefingInput
+
+
+TWITTER_API_BASE = "https://api.twitter.com/2"
+
+# Fields to request from Twitter API v2
+USER_FIELDS = "created_at,description,public_metrics,verified,profile_image_url"
+TWEET_FIELDS = "created_at,public_metrics,entities,referenced_tweets,lang,attachments"
+
+
+def _get_bearer_token(api_key: Optional[str] = None) -> Optional[str]:
+    """Get Twitter bearer token from parameter or environment."""
+    return api_key or settings.TWITTER_BEARER_TOKEN
+
+
+def _make_request(url: str, params: dict, bearer_token: str, max_retries: int = 3) -> Optional[dict]:
+    """Make authenticated Twitter API request with retry on rate limits."""
+    headers = {"Authorization": f"Bearer {bearer_token}"}
+
+    for attempt in range(max_retries):
+        try:
+            resp = requests.get(url, params=params, headers=headers, timeout=15)
+
+            if resp.status_code == 429:
+                # Rate limited — use reset header or exponential backoff
+                reset_time = resp.headers.get("x-rate-limit-reset")
+                if reset_time:
+                    wait_seconds = max(int(reset_time) - int(time.time()), 1)
+                    wait_seconds = min(wait_seconds, 60)  # Cap at 60s
+                else:
+                    wait_seconds = 2 ** (attempt + 1)
+                print(f"DEBUG: Twitter rate limited, waiting {wait_seconds}s (attempt {attempt + 1})")
+                time.sleep(wait_seconds)
+                continue
+
+            resp.raise_for_status()
+            return resp.json()
+
+        except requests.exceptions.HTTPError as e:
+            print(f"DEBUG: Twitter API HTTP error: {e}")
+            if resp.status_code in (401, 403):
+                print("DEBUG: Twitter auth error — check bearer token")
+                return None
+            if attempt < max_retries - 1:
+                time.sleep(2 ** (attempt + 1))
+                continue
+            return None
+        except requests.exceptions.RequestException as e:
+            print(f"DEBUG: Twitter API request error: {e}")
+            if attempt < max_retries - 1:
+                time.sleep(2 ** (attempt + 1))
+                continue
+            return None
+
+    return None
+
+
+def lookup_user(username: str, bearer_token: str) -> Optional[dict]:
+    """Resolve a Twitter username to user data including profile metrics."""
+    clean_username = username.lstrip("@").strip()
+    url = f"{TWITTER_API_BASE}/users/by/username/{clean_username}"
+    params = {"user.fields": USER_FIELDS}
+
+    data = _make_request(url, params, bearer_token)
+    if data and "data" in data:
+        return data["data"]
+
+    errors = data.get("errors", []) if data else []
+    if errors:
+        print(f"DEBUG: Twitter user lookup error: {errors[0].get('detail', 'unknown')}")
+    return None
+
+
+def fetch_user_tweets(user_id: str, count: int, bearer_token: str) -> List[dict]:
+    """Fetch recent tweets for a user by their Twitter ID."""
+    url = f"{TWITTER_API_BASE}/users/{user_id}/tweets"
+    params = {
+        "max_results": min(count, 100),  # API max is 100 per request
+        "tweet.fields": TWEET_FIELDS,
+    }
+
+    data = _make_request(url, params, bearer_token)
+    if data and "data" in data:
+        return data["data"]
+
+    return []
+
+
+def fetch_twitter_data(
+    handle: str,
+    num_posts: int = 10,
+    bearer_token: Optional[str] = None,
+) -> Optional[BriefingInput]:
+    """
+    Full Twitter data fetch: resolve user, get tweets, normalize via adapter.
+
+    Returns a BriefingInput ready for the analysis pipeline, or None on failure.
+    """
+    token = _get_bearer_token(bearer_token)
+    if not token:
+        print("DEBUG: No Twitter bearer token available")
+        return None
+
+    # Step 1: Look up user profile
+    user_data = lookup_user(handle, token)
+    if not user_data:
+        print(f"DEBUG: Could not find Twitter user: {handle}")
+        return None
+
+    user_id = user_data.get("id")
+    if not user_id:
+        return None
+
+    # Step 2: Fetch recent tweets
+    tweets = fetch_user_tweets(user_id, num_posts, token)
+    print(f"DEBUG: Fetched {len(tweets)} tweets for @{handle}")
+
+    # Step 3: Normalize via adapter
+    adapter = TwitterAdapter()
+    raw_data = {
+        "profile": user_data,
+        "posts": tweets,
+        "collection_period": {
+            "end": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
+        },
+        "data_source": "twitter_api_v2",
+    }
+    briefing_input = adapter.normalize(raw_data)
+
+    return briefing_input
+
+
+def briefing_input_to_articles(briefing_input: BriefingInput) -> List[Dict]:
+    """
+    Convert a BriefingInput into the article-like format expected by the pipeline.
+
+    This bridges the TwitterAdapter output into the same shape that fetch_articles()
+    returns, so the orchestrator can process both uniformly.
+    """
+    articles = []
+    for post in briefing_input.posts:
+        articles.append({
+            "title": post.text[:120] + ("..." if len(post.text) > 120 else ""),
+            "link": f"https://x.com/i/status/{post.post_id}" if post.post_id else "",
+            "snippet": post.text[:300],
+            "date": post.timestamp.isoformat() if post.timestamp else "",
+            "meta": {
+                "engagement": post.engagement,
+                "media_type": post.media_type,
+                "is_amplification": post.is_amplification,
+                "amplification_source": post.amplification_source,
+                "platform": "twitter",
+            },
+            "full_text": post.text,
+        })
+    return articles
