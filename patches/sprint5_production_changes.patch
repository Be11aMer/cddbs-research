+    return {
+        "serpapi": {
+            "configured": bool(settings.SERPAPI_KEY),
+            "status": "configured" if settings.SERPAPI_KEY else "not_configured",
+            "message": "SerpAPI key is configured" if settings.SERPAPI_KEY else "SerpAPI key not configured",
