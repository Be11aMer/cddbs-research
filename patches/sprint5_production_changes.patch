+            "configured": bool(settings.GOOGLE_API_KEY),
+            "status": "configured" if settings.GOOGLE_API_KEY else "not_configured",
+            "message": "Google API key is configured" if settings.GOOGLE_API_KEY else "Google API key not configured",
+        },
+        "twitter": {
