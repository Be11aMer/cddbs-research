+def _update_batch_progress(db: Session, batch_id: int, success: bool):
+    """Update batch completion counters after a target finishes."""
+    batch = db.query(Batch).filter(Batch.id == batch_id).first()
+    if not batch:
+        return
+    if success:
+        batch.completed_count = (batch.completed_count or 0) + 1
+    else:
+        batch.failed_count = (batch.failed_count or 0) + 1
+
+    total_done = (batch.completed_count or 0) + (batch.failed_count or 0)
+    if total_done >= batch.target_count:
+        batch.status = "completed" if (batch.failed_count or 0) == 0 else "completed_with_errors"
+    else:
+        batch.status = "running"
+    db.add(batch)
+    db.commit()
