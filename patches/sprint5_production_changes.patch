+
+    # Create batch record
+    batch = Batch(
+        name=payload.name or f"Batch ({len(payload.targets)} targets)",
+        status="queued",
+        target_count=len(payload.targets),
+    )
+    db.add(batch)
+    db.commit()
+    db.refresh(batch)
+
+    # Create a report for each target and schedule background jobs
+    report_ids = []
+    for target in payload.targets:
+        report = Report(
+            outlet=target.outlet,
+            country=target.country,
+            final_report=None,
+            data={
+                "outlet": target.outlet,
+                "url": target.url,
+                "country": target.country,
+                "analysis_date": datetime.now(UTC).isoformat(),
+                "articles_analyzed": 0,
+                "status": "pending",
+                "batch_id": batch.id,
+            },
+        )
+        db.add(report)
+        db.commit()
+        db.refresh(report)
+        report_ids.append(report.id)
+
+        background_tasks.add_task(
+            _run_analysis_job,
+            report_id=report.id,
+            outlet=target.outlet,
+            url=target.url,
+            country=target.country,
+            num_articles=target.num_articles,
+            serpapi_key=payload.serpapi_key,
+            google_api_key=payload.google_api_key,
+            date_filter=target.date_filter,
+            platform=target.platform,
+            twitter_bearer_token=payload.twitter_bearer_token,
+            batch_id=batch.id,
+        )
+
+    # Store report IDs on the batch
+    batch.report_ids = report_ids
+    batch.status = "running"
+    db.add(batch)
+    db.commit()
+    db.refresh(batch)
+
+    return BatchStatusResponse(
+        id=batch.id,
+        name=batch.name,
+        status=batch.status,
+        target_count=batch.target_count,
+        completed_count=0,
+        failed_count=0,
+        report_ids=report_ids,
+        created_at=batch.created_at,
+    )
+
+
+@app.get("/analysis-runs/batch/{batch_id}", response_model=BatchStatusResponse)
+def get_batch_status(batch_id: int, db: Session = Depends(get_db)):
+    """Get the status of a batch analysis."""
+    batch = db.query(Batch).filter(Batch.id == batch_id).first()
+    if not batch:
+        raise HTTPException(status_code=404, detail="Batch not found")
+
+    return BatchStatusResponse(
+        id=batch.id,
+        name=batch.name,
+        status=batch.status,
+        target_count=batch.target_count,
+        completed_count=batch.completed_count or 0,
+        failed_count=batch.failed_count or 0,
+        report_ids=batch.report_ids or [],
+        created_at=batch.created_at,
+    )
+
+
+@app.get("/batches", response_model=List[BatchStatusResponse])
+def list_batches(db: Session = Depends(get_db)):
+    """List all batch analyses."""
+    batches = db.query(Batch).order_by(Batch.created_at.desc()).all()
+    return [
+        BatchStatusResponse(
+            id=b.id,
+            name=b.name,
+            status=b.status,
+            target_count=b.target_count,
+            completed_count=b.completed_count or 0,
+            failed_count=b.failed_count or 0,
+            report_ids=b.report_ids or [],
+            created_at=b.created_at,
+        )
+        for b in batches
+    ]
+
+
+# ---------------------------------------------------------------------------
+# Sprint 5: Export
+# ---------------------------------------------------------------------------
+
+
+@app.get("/analysis-runs/{report_id}/export")
+def export_report(
+    report_id: int,
+    format: str = "json",
+    db: Session = Depends(get_db),
+):
+    """Export an analysis report in JSON, CSV, or PDF format."""
+    report = db.query(Report).filter(Report.id == report_id).first()
+    if not report:
+        raise HTTPException(status_code=404, detail="Report not found")
+
+    briefing = db.query(Briefing).filter(Briefing.report_id == report_id).first()
+    narratives = db.query(NarrativeMatch).filter(
+        NarrativeMatch.report_id == report_id
+    ).order_by(NarrativeMatch.match_count.desc()).all()
+    articles = report.articles
+
+    if format == "json":
+        content = export_json(report, briefing, narratives, articles)
+        return Response(
+            content=content,
+            media_type="application/json",
+            headers={"Content-Disposition": f"attachment; filename=cddbs_report_{report_id}.json"},
+        )
+    elif format == "csv":
+        content = export_csv(report, briefing, narratives, articles)
+        return Response(
+            content=content,
+            media_type="text/csv",
+            headers={"Content-Disposition": f"attachment; filename=cddbs_report_{report_id}.csv"},
+        )
+    elif format == "pdf":
+        content = export_pdf(report, briefing, narratives, articles)
+        if content is None:
+            raise HTTPException(status_code=501, detail="PDF export not available (reportlab not installed)")
+        return Response(
+            content=content,
+            media_type="application/pdf",
+            headers={"Content-Disposition": f"attachment; filename=cddbs_report_{report_id}.pdf"},
+        )
+    else:
+        raise HTTPException(status_code=400, detail=f"Unsupported format: {format}. Use json, csv, or pdf.")
+
+
+# ---------------------------------------------------------------------------
+# Sprint 5: Metrics
+# ---------------------------------------------------------------------------
+
+
+@app.get("/metrics")
+def get_metrics(db: Session = Depends(get_db)):
+    """Return operational metrics across all analysis runs."""
+    return compute_metrics(db)
+
+
+@app.get("/api-status")
+def api_status_extended():
+    """
+    Check configuration status of external APIs.
+    Extended in Sprint 5 with Twitter status.
