@@ -0,0 +1,215 @@
+"""
+CDDBS Export Module
+
+Generates analysis reports in JSON, CSV, and PDF formats for offline sharing.
+"""
+
+import csv
+import io
+import json
+from datetime import datetime, UTC
+from typing import Optional
+
+
+def export_json(report, briefing, narrative_matches, articles) -> str:
+    """Export a complete analysis report as structured JSON."""
+    data = {
+        "export_metadata": {
+            "format": "json",
+            "version": "1.0",
+            "exported_at": datetime.now(UTC).isoformat(),
+            "system": "CDDBS",
+        },
+        "report": {
+            "id": report.id,
+            "outlet": report.outlet,
+            "country": report.country,
+            "created_at": report.created_at.isoformat() if report.created_at else None,
+            "final_report": report.final_report,
+            "articles_analyzed": (report.data or {}).get("articles_analyzed", 0),
+        },
+        "quality": None,
+        "narratives": [],
+        "articles": [],
+    }
+
+    if briefing:
+        data["quality"] = {
+            "score": briefing.quality_score,
+            "max_score": 70,
+            "rating": briefing.quality_rating,
+            "prompt_version": briefing.prompt_version,
+            "details": briefing.quality_details,
+        }
+
+    for nm in narrative_matches:
+        data["narratives"].append({
+            "narrative_id": nm.narrative_id,
+            "narrative_name": nm.narrative_name,
+            "category": nm.category,
+            "confidence": nm.confidence,
+            "matched_keywords": nm.matched_keywords,
+            "match_count": nm.match_count,
+        })
+
+    for a in articles:
+        data["articles"].append({
+            "id": a.id,
+            "title": a.title,
+            "link": a.link,
+            "snippet": a.snippet,
+            "date": a.date,
+        })
+
+    return json.dumps(data, indent=2, default=str)
+
+
+def export_csv(report, briefing, narrative_matches, articles) -> str:
+    """Export analysis data as CSV (flattened tabular format)."""
+    output = io.StringIO()
+
+    # Section 1: Report summary
+    writer = csv.writer(output)
+    writer.writerow(["# CDDBS Analysis Export"])
+    writer.writerow([])
+    writer.writerow(["Report ID", "Outlet", "Country", "Created", "Quality Score", "Quality Rating", "Articles Analyzed"])
+    writer.writerow([
+        report.id,
+        report.outlet,
+        report.country,
+        report.created_at.isoformat() if report.created_at else "",
+        briefing.quality_score if briefing else "",
+        briefing.quality_rating if briefing else "",
+        (report.data or {}).get("articles_analyzed", 0),
+    ])
+    writer.writerow([])
+
+    # Section 2: Articles
+    writer.writerow(["# Articles"])
+    writer.writerow(["Article ID", "Title", "Link", "Date", "Snippet"])
+    for a in articles:
+        writer.writerow([a.id, a.title, a.link, a.date, (a.snippet or "")[:200]])
+    writer.writerow([])
+
+    # Section 3: Narrative Matches
+    writer.writerow(["# Narrative Matches"])
+    writer.writerow(["Narrative ID", "Name", "Category", "Confidence", "Match Count", "Keywords"])
+    for nm in narrative_matches:
+        keywords = ", ".join(nm.matched_keywords) if nm.matched_keywords else ""
+        writer.writerow([nm.narrative_id, nm.narrative_name, nm.category, nm.confidence, nm.match_count, keywords])
+
+    return output.getvalue()
+
+
+def export_pdf(report, briefing, narrative_matches, articles) -> Optional[bytes]:
+    """
+    Export analysis as a formatted PDF report.
+
+    Uses reportlab if available, otherwise returns None.
+    """
+    try:
+        from reportlab.lib.pagesizes import A4
+        from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
+        from reportlab.lib.units import inch
+        from reportlab.lib.colors import HexColor
+        from reportlab.platypus import (
+            SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle,
+        )
+    except ImportError:
+        print("DEBUG: reportlab not installed, PDF export unavailable")
+        return None
+
+    buffer = io.BytesIO()
+    doc = SimpleDocTemplate(buffer, pagesize=A4, topMargin=0.75 * inch, bottomMargin=0.75 * inch)
+
+    styles = getSampleStyleSheet()
+    title_style = ParagraphStyle(
+        "CDDBSTitle",
+        parent=styles["Title"],
+        fontSize=18,
+        textColor=HexColor("#1a237e"),
+        spaceAfter=12,
+    )
+    heading_style = ParagraphStyle(
+        "CDDBSHeading",
+        parent=styles["Heading2"],
+        fontSize=13,
+        textColor=HexColor("#1565c0"),
+        spaceAfter=8,
+        spaceBefore=16,
+    )
+    body_style = styles["BodyText"]
+    body_style.spaceAfter = 6
+
+    elements = []
+
+    # Title
+    elements.append(Paragraph("CDDBS Intelligence Briefing", title_style))
+    elements.append(Spacer(1, 8))
+
+    # Report metadata
+    quality_str = f"{briefing.quality_score}/70 ({briefing.quality_rating})" if briefing else "N/A"
+    meta_data = [
+        ["Outlet", report.outlet],
+        ["Country", report.country or "N/A"],
+        ["Date", report.created_at.strftime("%Y-%m-%d %H:%M UTC") if report.created_at else "N/A"],
+        ["Articles Analyzed", str((report.data or {}).get("articles_analyzed", 0))],
+        ["Quality Score", quality_str],
+    ]
+    meta_table = Table(meta_data, colWidths=[1.8 * inch, 4.5 * inch])
+    meta_table.setStyle(TableStyle([
+        ("FONTNAME", (0, 0), (0, -1), "Helvetica-Bold"),
+        ("FONTSIZE", (0, 0), (-1, -1), 9),
+        ("BOTTOMPADDING", (0, 0), (-1, -1), 4),
+        ("TOPPADDING", (0, 0), (-1, -1), 2),
+    ]))
+    elements.append(meta_table)
+    elements.append(Spacer(1, 12))
+
+    # Narrative matches
+    if narrative_matches:
+        elements.append(Paragraph("Detected Narratives", heading_style))
+        for nm in narrative_matches:
+            elements.append(Paragraph(
+                f"<b>{nm.narrative_name}</b> — {nm.confidence} confidence ({nm.match_count} keyword matches)",
+                body_style,
+            ))
+
+    # Briefing content
+    if report.final_report:
+        elements.append(Paragraph("Intelligence Briefing", heading_style))
+        for paragraph in report.final_report.split("\n\n"):
+            clean = paragraph.strip()
+            if not clean:
+                continue
+            # Handle markdown headers
+            if clean.startswith("# "):
+                elements.append(Paragraph(clean[2:], heading_style))
+            elif clean.startswith("## "):
+                elements.append(Paragraph(clean[3:], heading_style))
+            else:
+                # Escape XML special chars for reportlab
+                clean = clean.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
+                elements.append(Paragraph(clean, body_style))
+
+    # Articles
+    if articles:
+        elements.append(Paragraph("Source Articles", heading_style))
+        for a in articles:
+            title = (a.title or "Untitled").replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
+            elements.append(Paragraph(f"<b>{title}</b>", body_style))
+            if a.link:
+                link = a.link.replace("&", "&amp;")
+                elements.append(Paragraph(f"<i>{link}</i>", body_style))
+
+    # Footer
+    elements.append(Spacer(1, 24))
+    footer_style = ParagraphStyle("Footer", parent=body_style, fontSize=7, textColor=HexColor("#666666"))
+    elements.append(Paragraph(
+        f"Generated by CDDBS on {datetime.now(UTC).strftime('%Y-%m-%d %H:%M UTC')}. "
+        "This is an automated analysis and should be verified by qualified analysts.",
+        footer_style,
+    ))
+
+    doc.build(elements)
+    return buffer.getvalue()
