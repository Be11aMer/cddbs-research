{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CDDBS Intelligence Briefing v1.2",
  "description": "Schema for CDDBS v1.2 intelligence briefing output. Extends v1.1 with multi-platform support (Telegram), cross-platform identity linking, and enhanced network analysis.",
  "version": "1.2.0",
  "type": "object",
  "required": [
    "metadata",
    "executive_summary",
    "key_findings",
    "subject_profile",
    "confidence_assessment",
    "limitations",
    "methodology"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Briefing metadata and provenance information",
      "required": ["briefing_id", "generated_at", "model_version", "prompt_version", "cddbs_version"],
      "properties": {
        "briefing_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for this briefing"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of briefing generation"
        },
        "model_version": {
          "type": "string",
          "description": "LLM model identifier used for analysis (e.g., gemini-1.5-pro)"
        },
        "prompt_version": {
          "type": "string",
          "description": "System prompt version (e.g., v1.3)"
        },
        "cddbs_version": {
          "type": "string",
          "description": "CDDBS application version (e.g., 1.3.0)"
        },
        "analysis_period": {
          "type": "object",
          "description": "Time range of data included in analysis",
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "string", "format": "date" },
            "end": { "type": "string", "format": "date" }
          }
        }
      }
    },

    "executive_summary": {
      "type": "string",
      "description": "2-3 sentence overview: (1) assessed nature of account, (2) why it matters, (3) confidence level. Inspired by RAND key findings box.",
      "minLength": 50,
      "maxLength": 1000
    },

    "key_findings": {
      "type": "array",
      "description": "Ordered list of 3-5 key findings, each with per-finding confidence (CDDBS innovation).",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["finding", "confidence", "evidence"],
        "properties": {
          "finding": {
            "type": "string",
            "description": "Clear, specific, actionable finding statement"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "moderate", "low"],
            "description": "Confidence level for this specific finding"
          },
          "evidence": {
            "type": "array",
            "description": "Evidence supporting this finding",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["type", "reference"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["post", "pattern", "network", "metadata", "external", "forward", "channel_meta"],
                  "description": "Evidence type label. v1.2 adds: forward=Telegram forwarded message chain, channel_meta=Telegram channel/group metadata"
                },
                "reference": {
                  "type": "string",
                  "description": "Specific reference to the evidence (URL, description with metrics, source citation)"
                }
              }
            }
          }
        }
      }
    },

    "subject_profile": {
      "type": "object",
      "description": "Structured account metadata. Inspired by EUvsDisinfo consistent entries and DFRLab profiling.",
      "required": ["account_handle", "platform"],
      "properties": {
        "account_handle": {
          "type": "string",
          "description": "The subject account's handle/username"
        },
        "platform": {
          "type": "string",
          "enum": ["twitter", "telegram", "facebook", "instagram", "youtube", "tiktok", "vkontakte", "other"],
          "description": "Primary social media platform"
        },
        "account_created": {
          "type": "string",
          "format": "date",
          "description": "Account creation date if known"
        },
        "followers": {
          "type": "integer",
          "minimum": 0,
          "description": "Follower/subscriber count at time of analysis"
        },
        "following": {
          "type": "integer",
          "minimum": 0,
          "description": "Following count at time of analysis (N/A for Telegram channels)"
        },
        "total_posts_analyzed": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of posts/messages included in analysis"
        },
        "account_bio": {
          "type": "string",
          "description": "Current bio/description text"
        },
        "profile_language": {
          "type": "string",
          "description": "Primary language of profile and posts"
        },
        "verified": {
          "type": "boolean",
          "description": "Whether the account has platform verification"
        },
        "platform_metadata": {
          "type": "object",
          "description": "Platform-specific metadata fields (v1.2). Contents vary by platform.",
          "properties": {
            "telegram_channel_type": {
              "type": "string",
              "enum": ["channel", "group", "supergroup", "bot"],
              "description": "Telegram entity type"
            },
            "telegram_subscriber_count": {
              "type": "integer",
              "minimum": 0,
              "description": "Telegram channel/group subscriber count"
            },
            "telegram_is_verified": {
              "type": "boolean",
              "description": "Whether the Telegram channel has a verified badge"
            },
            "telegram_linked_chat": {
              "type": "string",
              "description": "Linked discussion group handle (for channels with comment sections)"
            },
            "telegram_invite_link": {
              "type": "string",
              "description": "Public invite link if available"
            },
            "twitter_list_memberships": {
              "type": "integer",
              "description": "Number of Twitter lists the account is a member of"
            },
            "twitter_is_blue_verified": {
              "type": "boolean",
              "description": "Whether the account has Twitter Blue/Premium verification"
            }
          }
        }
      }
    },

    "narrative_analysis": {
      "type": "object",
      "description": "Multi-dimensional content and behavioral analysis. Inspired by GEC pillars, OII comparative framework, Graphika network+semantic+temporal approach.",
      "properties": {
        "primary_narratives": {
          "type": "array",
          "description": "Dominant narratives promoted by this account",
          "items": {
            "type": "object",
            "required": ["narrative", "frequency"],
            "properties": {
              "narrative": {
                "type": "string",
                "description": "Clear description of the narrative"
              },
              "frequency": {
                "type": "string",
                "enum": ["dominant", "frequent", "occasional"],
                "description": "How often this narrative appears"
              },
              "alignment": {
                "type": "string",
                "description": "Known campaign or state narrative this aligns with (if any)"
              }
            }
          }
        },
        "behavioral_indicators": {
          "type": "array",
          "description": "Observable behavioral patterns. Each should use precise attribution language.",
          "items": {
            "type": "object",
            "required": ["indicator", "description"],
            "properties": {
              "indicator": {
                "type": "string",
                "enum": [
                  "posting_frequency", "language_patterns", "engagement_ratio",
                  "coordination_signals", "timing_patterns", "content_amplification",
                  "forwarding_pattern", "channel_growth", "bot_activity",
                  "message_deletion", "other"
                ],
                "description": "Type of behavioral indicator. v1.2 adds Telegram-specific: forwarding_pattern, channel_growth, bot_activity, message_deletion"
              },
              "description": {
                "type": "string",
                "description": "Specific observation with metrics where possible"
              }
            }
          }
        },
        "network_context": {
          "type": "object",
          "description": "Network relationships and amplification patterns",
          "properties": {
            "known_associations": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Accounts frequently interacted with"
            },
            "amplification_patterns": {
              "type": "string",
              "description": "Who amplifies this account and who this account amplifies"
            },
            "cross_platform_presence": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Same identity on other platforms"
            }
          }
        },
        "source_attribution": {
          "type": "object",
          "description": "Assessment of where narratives originate. Inspired by GEC pillar classification.",
          "properties": {
            "role": {
              "type": "string",
              "enum": ["official_state_media", "proxy", "deniable", "authentic", "unknown"],
              "description": "Assessed role in the disinformation ecosystem"
            },
            "content_origin": {
              "type": "string",
              "description": "Where narratives appear to originate"
            },
            "amplification_chain": {
              "type": "string",
              "description": "How content reaches this account"
            }
          }
        }
      }
    },

    "cross_platform_identities": {
      "type": "array",
      "description": "Cross-platform identity links for this entity (v1.2). Documents the same actor's presence across multiple platforms.",
      "items": {
        "type": "object",
        "required": ["platform", "handle", "confidence"],
        "properties": {
          "platform": {
            "type": "string",
            "enum": ["twitter", "telegram", "facebook", "instagram", "youtube", "tiktok", "vkontakte", "other"],
            "description": "Platform where linked identity exists"
          },
          "handle": {
            "type": "string",
            "description": "Account handle on the linked platform"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "moderate", "low"],
            "description": "Confidence in the identity link"
          },
          "linking_evidence": {
            "type": "string",
            "description": "Evidence supporting the cross-platform link (e.g., bio cross-reference, content timing, shared URLs)"
          },
          "briefing_id": {
            "type": "string",
            "format": "uuid",
            "description": "CDDBS briefing ID for this linked identity, if one exists"
          }
        }
      }
    },

    "network_graph": {
      "type": "object",
      "description": "Network graph data for visualization and analysis (v1.2). Captures the amplification/interaction network around the subject.",
      "properties": {
        "nodes": {
          "type": "array",
          "description": "Network nodes (accounts/entities)",
          "items": {
            "type": "object",
            "required": ["id", "platform"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Node identifier (typically account handle)"
              },
              "platform": {
                "type": "string",
                "enum": ["twitter", "telegram", "facebook", "instagram", "youtube", "tiktok", "vkontakte", "other"]
              },
              "role": {
                "type": "string",
                "enum": ["subject", "source", "amplifier", "target", "peer", "unknown"],
                "description": "Role of this node relative to the subject"
              },
              "label": {
                "type": "string",
                "description": "Display label for visualization"
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "description": "Network edges (interactions/relationships)",
          "items": {
            "type": "object",
            "required": ["from", "to", "type"],
            "properties": {
              "from": {
                "type": "string",
                "description": "Source node ID"
              },
              "to": {
                "type": "string",
                "description": "Target node ID"
              },
              "type": {
                "type": "string",
                "enum": ["retweet", "reply", "mention", "forward", "quote", "follow", "amplification"],
                "description": "Type of interaction"
              },
              "weight": {
                "type": "integer",
                "minimum": 1,
                "description": "Interaction count/strength"
              }
            }
          }
        },
        "communities": {
          "type": "array",
          "description": "Detected network communities/clusters",
          "items": {
            "type": "object",
            "required": ["id", "members"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Community identifier"
              },
              "label": {
                "type": "string",
                "description": "Descriptive label for the community"
              },
              "members": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Node IDs belonging to this community"
              }
            }
          }
        }
      }
    },

    "confidence_assessment": {
      "type": "object",
      "description": "Formal confidence framework. Synthesized from Graphika (multi-dimensional), NATO StratCom (assessment language), intelligence community standards.",
      "required": ["overall", "factors"],
      "properties": {
        "overall": {
          "type": "string",
          "enum": ["high", "moderate", "low"],
          "description": "Overall confidence in the assessment"
        },
        "factors": {
          "type": "object",
          "description": "Per-factor confidence breakdown (CDDBS innovation)",
          "required": ["data_completeness", "source_reliability", "analytical_consistency", "corroboration"],
          "properties": {
            "data_completeness": {
              "type": "string",
              "enum": ["high", "moderate", "low"],
              "description": "How complete is the data available for analysis?"
            },
            "source_reliability": {
              "type": "string",
              "enum": ["high", "moderate", "low"],
              "description": "How reliable are the data sources used?"
            },
            "analytical_consistency": {
              "type": "string",
              "enum": ["high", "moderate", "low"],
              "description": "How consistent are the indicators across dimensions?"
            },
            "corroboration": {
              "type": "string",
              "enum": ["high", "moderate", "low"],
              "description": "Multiple independent indicators supporting the assessment?"
            }
          }
        }
      }
    },

    "limitations": {
      "type": "object",
      "description": "Mandatory limitations section. Inspired by Bellingcat's explicit gaps and SIO's transparency.",
      "required": ["cannot_determine", "data_gaps"],
      "properties": {
        "cannot_determine": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What this analysis cannot establish"
        },
        "data_gaps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known missing data"
        },
        "alternative_interpretations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Plausible alternative explanations for observed behavior"
        },
        "assessment_changing_factors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What new evidence would change this assessment"
        }
      }
    },

    "methodology": {
      "type": "object",
      "description": "Methodology transparency. Inspired by SIO, OII, DFRLab.",
      "required": ["data_collection", "analysis_model", "prompt_version"],
      "properties": {
        "data_collection": {
          "type": "string",
          "description": "How data was gathered (API, scraping, manual)"
        },
        "collection_period": {
          "type": "object",
          "properties": {
            "start": { "type": "string", "format": "date" },
            "end": { "type": "string", "format": "date" }
          }
        },
        "posts_analyzed": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of posts analyzed"
        },
        "analysis_model": {
          "type": "string",
          "description": "LLM model used for analysis"
        },
        "prompt_version": {
          "type": "string",
          "description": "System prompt version"
        },
        "validation": {
          "type": "string",
          "description": "Any human review or cross-checking performed"
        }
      }
    },

    "evidence_references": {
      "type": "array",
      "description": "Full evidence reference table. Inspired by Bellingcat and DFRLab.",
      "items": {
        "type": "object",
        "required": ["type", "reference"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Reference number for cross-referencing from findings"
          },
          "type": {
            "type": "string",
            "enum": ["post", "pattern", "network", "metadata", "external", "forward", "channel_meta"]
          },
          "reference": {
            "type": "string",
            "description": "URL, archived link, or detailed description"
          },
          "notes": {
            "type": "string",
            "description": "Context about the evidence"
          }
        }
      }
    },

    "related_briefings": {
      "type": "array",
      "description": "IDs of related CDDBS briefings for cross-referencing",
      "items": {
        "type": "object",
        "properties": {
          "briefing_id": { "type": "string", "format": "uuid" },
          "subject": { "type": "string" },
          "relationship": { "type": "string" }
        }
      }
    }
  }
}
